{
    "name": "holy-js-childs-monorepo",
    "private": true,
    "scripts": {
        "start": "tramvai start holy-js-childs",
        "build": "tramvai build holy-js-childs",
        "preview": "tramvai start-prod holy-js-childs",
        "analyze": "tramvai holy-js-childs --analyze=statoscope",
        "lint": "eslint --ext .ts,.tsx --ignore-path .gitignore .",
        "test": "jest --passWithNoTests",
        "test:watch": "jest --watch",
        "test:integration": "playwright test",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build"
    },
    "husky": {
        "hooks": {
            "pre-commit": "lint-staged"
        }
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx}": [
            "eslint --fix"
        ]
    },
    "workspaces": [
        "child-apps/*"
    ],
    "packageManager": "yarn@4.13.0",
    "dependencies": {
        "tslib": "^2.0.3"
    },
    "devDependencies": {
        "@chromatic-com/storybook": "^3.2.0",
        "@storybook/addon-a11y": "^8.6.14",
        "@storybook/addon-essentials": "8.6.14",
        "@storybook/addon-links": "^8.6.14",
        "@storybook/react": "^8.6.14",
        "@storybook/react-vite": "^8.6.14",
        "@tramvai/cli": "^6.79.33",
        "@types/react": "^19.2.14",
        "@typescript-eslint/eslint-plugin": "^8.0.0",
        "@typescript-eslint/parser": "^8.0.0",
        "@vitejs/plugin-react": "^6.0.1",
        "eslint": "^8.57.0",
        "eslint-plugin-css-modules": "^2.12.0",
        "eslint-plugin-jest": "^29.15.2",
        "eslint-plugin-playwright": "^2.10.2",
        "eslint-plugin-react": "^7.37.0",
        "eslint-plugin-react-hooks": "^5.0.0",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "storybook": "^8.6.14",
        "vite": "^8.0.9"
    }
}
