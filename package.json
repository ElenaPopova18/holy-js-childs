{
    "name": "holy-js-childs-monorepo",
    "private": true,
    "scripts": {
        "start": "tramvai start holy-js-childs",
        "build": "tramvai build holy-js-childs",
        "preview": "tramvai start-prod holy-js-childs",
        "analyze": "tramvai holy-js-childs --analyze=statoscope",
        "lint": "eslint .",
        "lint:file": "eslint --ext .ts,.tsx",
        "lint:step1": "yarn lint:file child-apps/holy-js-childs/components/root.utils.ts",
        "lint:step2": "yarn lint:file child-apps/holy-js-childs/components/root.tsx",
        "test": "jest --passWithNoTests",
        "test:big-mf": "yarn test --testPathPattern=\"big-conf-mf\"",
        "test:integration": "playwright test",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build",
        "test-storybook": "test-storybook",
        "test-storybook:coverage": "start-server-and-test 'COVERAGE=true storybook dev -p 6006' http://127.0.0.1:6006 'test-storybook --coverage && nyc report --reporter=html --reporter=text --reporter=lcov --report-dir=./coverage/storybook/html --temp-dir=./coverage/storybook'"
    },
    "husky": {
        "hooks": {
            "pre-commit": "lint-staged"
        }
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx}": [
            "eslint --fix"
        ]
    },
    "workspaces": [
        "child-apps/*"
    ],
    "packageManager": "yarn@4.14.1",
    "dependencies": {
        "@tramvai/child-app-core": "^6.79.33",
        "@tramvai/core": "^6.79.33",
        "@tramvai/react": "^6.79.33",
        "@tramvai/state": "^6.79.33",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "tslib": "^2.0.3"
    },
    "devDependencies": {
        "@chromatic-com/storybook": "^3.2.0",
        "@istanbuljs/nyc-config-typescript": "^1.0.2",
        "@jest/types": "^29.6.3",
        "@playwright/test": "^1.58.2",
        "@storybook/addon-a11y": "^8.6.14",
        "@storybook/addon-coverage": "^3.0.1",
        "@storybook/addon-essentials": "8.6.14",
        "@storybook/addon-links": "^8.6.14",
        "@storybook/react": "^8.6.14",
        "@storybook/react-vite": "^8.6.14",
        "@storybook/test-runner": "^0.24.3",
        "@testing-library/react": "^16.3.2",
        "@tinkoff/eslint-config": "^5.2.1",
        "@tinkoff/eslint-config-react": "^5.2.1",
        "@tinkoff/eslint-plugin-tramvai": "^0.10.9",
        "@tramvai/cli": "^6.79.33",
        "@tramvai/module-child-app": "^6.80.26",
        "@tramvai/prettier-config": "^1.0.3",
        "@tramvai/swc-integration": "^6.79.33",
        "@tramvai/test-child-app": "^6.79.33",
        "@tramvai/test-react": "^6.79.33",
        "@tramvai/test-unit": "^6.79.33",
        "@tramvai/test-unit-jest": "^6.79.33",
        "@types/jest": "^29.5.12",
        "@types/react": "^19.2.14",
        "@typescript-eslint/eslint-plugin": "^8.0.0",
        "@typescript-eslint/parser": "^8.0.0",
        "@vitejs/plugin-react": "^6.0.1",
        "babel-plugin-istanbul": "8.0.0",
        "eslint": "9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-complexity": "^1.0.2",
        "eslint-plugin-css-modules": "^2.12.0",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-jest": "^29.15.2",
        "eslint-plugin-playwright": "^2.10.2",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-react": "^7.37.0",
        "eslint-plugin-react-hooks": "^5.0.0",
        "husky": "^4",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^29.7.0",
        "lint-staged": "^16.4.0",
        "nyc": "^18.0.0",
        "playwright": "^1.59.1",
        "postcss-custom-media": "^12.0.1",
        "postcss-custom-properties": "^15.0.1",
        "postcss-modules-values-replace": "^4.2.2",
        "postcss-nested": "^7.0.2",
        "prettier": "^3.8.3",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "source-map": "^0.7.6",
        "source-map-support": "^0.5.21",
        "start-server-and-test": "^3.0.2",
        "storybook": "^8.6.14",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3",
        "vite": "^8.0.9",
        "webpack-sources": "^3.3.4"
    }
}
